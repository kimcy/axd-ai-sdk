{
  "conversation_created": {
    "type": "metadata",
    "wrap": "data",
    "fields": {
      "conversationId": "conversationId"
    }
  },
  "message_created": {
    "type": "message-start",
    "fields": {
      "messageId": "messageId"
    }
  },
  "thinking": {
    "type": "thinking-step",
    "wrap": "step",
    "fields": {
      "agent": "agent",
      "status": "status",
      "thought": "thought"
    }
  },
  "message": {
    "type": "text-delta",
    "fields": {
      "delta": "content"
    }
  },
  "done": {
    "type": "finish"
  }
}
